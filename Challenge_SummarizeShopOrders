def summarize_orders(orders):
    item_totals = {}
    customer_totals = {}
    unique_customers_per_item = {}

    for order in orders:
        customer = order["customer"]
        items = order["items"]

        order_total_quantity = 0

        for item_name in items:
            quantity = items[item_name]

            if item_name in item_totals:
                item_totals[item_name] = item_totals[item_name] + quantity
            else:
                item_totals[item_name] = quantity

            order_total_quantity = order_total_quantity + quantity

            if item_name not in unique_customers_per_item:
                unique_customers_per_item[item_name] = set()

            unique_customers_per_item[item_name].add(customer)

        if customer in customer_totals:
            customer_totals[customer] = customer_totals[customer] + order_total_quantity
        else:
            customer_totals[customer] = order_total_quantity

    result = {
        "item_totals": item_totals,
        "customer_totals": customer_totals,
        "unique_customers_per_item": unique_customers_per_item,
    }

    return result
